{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://synapse.dev/schemas/manifest.schema.json",
  "title": "Synapse Plugin Manifest",
  "description": "Configuration file for a Synapse plugin (.synx package). Defines metadata, permissions, authentication, triggers, and settings.",
  "type": "object",
  "required": ["id", "name", "version", "triggers"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference (for editor autocomplete)"
    },
    "id": {
      "type": "string",
      "description": "Unique reverse-domain plugin identifier (e.g., com.notion.add, com.jira.create-ticket)",
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$",
      "examples": ["com.notion.add", "com.jira.create-ticket", "com.synapse.todo"]
    },
    "name": {
      "type": "string",
      "description": "Human-readable plugin name displayed in the UI",
      "minLength": 1,
      "maxLength": 50,
      "examples": ["Add to Notion", "Create Jira Ticket"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the plugin",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "2.1.3"]
    },
    "description": {
      "type": "string",
      "description": "Brief description of what the plugin does (shown in marketplace)",
      "maxLength": 200
    },
    "author": {
      "type": "string",
      "description": "Plugin author name"
    },
    "authorUrl": {
      "type": "string",
      "description": "URL to the author's website or profile",
      "format": "uri"
    },
    "homepage": {
      "type": "string",
      "description": "URL to the plugin's homepage or repository",
      "format": "uri"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g., MIT, Apache-2.0)",
      "examples": ["MIT", "Apache-2.0", "ISC"]
    },
    "minSynapseVersion": {
      "type": "string",
      "description": "Minimum required Synapse app version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "security": {
      "type": "object",
      "description": "Security and permission configuration",
      "properties": {
        "allowedDomains": {
          "type": "array",
          "description": "Domains the plugin is allowed to make network requests to. Only these domains will be reachable via synapse.fetch().",
          "items": {
            "type": "string",
            "description": "Domain name (e.g., api.notion.com)",
            "examples": ["api.notion.com", "api.github.com"]
          },
          "uniqueItems": true
        },
        "permissions": {
          "type": "array",
          "description": "Capabilities the plugin requires. The host will prompt the user to grant these.",
          "items": {
            "type": "string",
            "enum": ["network", "ui", "storage", "config", "calendar", "applescript", "shortcuts", "intents"],
            "description": "Permission type"
          },
          "uniqueItems": true
        },
        "contentHash": {
          "type": "string",
          "description": "SHA-256 hash of plugin.js (auto-generated by 'synapse package'). Do not edit manually."
        },
        "allowedApps": {
          "type": "array",
          "description": "macOS apps the plugin is allowed to target via AppleScript (required if using 'applescript' permission)",
          "items": {
            "type": "string",
            "examples": ["Notes", "Reminders", "Calendar", "Music"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "description": "Authentication configuration. OAuth flows are handled by the host — the plugin never sees raw tokens.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["oauth2", "api_key", "none"],
          "description": "Authentication method: 'oauth2' for OAuth providers, 'api_key' for user-provided keys, 'none' for no auth",
          "default": "none"
        },
        "provider": {
          "type": "string",
          "description": "OAuth provider identifier (e.g., 'notion', 'google', 'jira'). Used with synapse.fetch({ provider: '...' }) to auto-inject Authorization headers.",
          "examples": ["notion", "google", "jira", "github", "slack"]
        },
        "scopes": {
          "type": "array",
          "description": "Required OAuth scopes",
          "items": {
            "type": "string"
          },
          "examples": [["read:jira-work", "write:jira-work"]]
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": { "type": { "const": "oauth2" } }
      },
      "then": {
        "required": ["provider"]
      }
    },
    "config": {
      "type": "array",
      "description": "User-configurable settings. The host auto-generates a settings UI from these definitions.",
      "items": {
        "type": "object",
        "required": ["key", "label", "type"],
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique key used with synapse.config.get('key')",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "label": {
            "type": "string",
            "description": "Display label shown in the settings UI"
          },
          "type": {
            "type": "string",
            "enum": ["text", "password", "number", "boolean", "select"],
            "description": "Input field type: 'password' for secrets (stored encrypted), 'select' for dropdowns"
          },
          "default": {
            "type": "string",
            "description": "Default value if not set by the user"
          },
          "description": {
            "type": "string",
            "description": "Help text shown below the field"
          },
          "required": {
            "type": "boolean",
            "description": "Whether the field must be set before the plugin can run",
            "default": false
          },
          "options": {
            "type": "array",
            "description": "Options for 'select' type fields",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false,
        "if": {
          "properties": { "type": { "const": "select" } }
        },
        "then": {
          "required": ["options"]
        }
      }
    },
    "triggers": {
      "type": "array",
      "description": "Intent names this plugin handles. Each must have a matching synapse.register() call in plugin.js.",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "description": "Intent name (lowercase with underscores)",
        "examples": ["add_to_notion", "create_ticket", "search_docs"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "inputSchema": {
      "type": "object",
      "description": "JSON Schema describing the expected input parameters for this plugin. Used by the host for validation.",
      "properties": {
        "type": {
          "type": "string",
          "const": "object"
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["string", "number", "boolean", "array", "object"]
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "required": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "categories": {
      "type": "array",
      "description": "Marketplace categories for discovery",
      "items": {
        "type": "string",
        "enum": ["productivity", "communication", "developer-tools", "social", "media", "utilities", "finance", "health", "education", "entertainment"],
        "description": "Plugin category"
      },
      "uniqueItems": true
    },
    "keywords": {
      "type": "array",
      "description": "Search keywords for marketplace discovery",
      "items": {
        "type": "string"
      },
      "maxItems": 10
    }
  },
  "additionalProperties": false
}
