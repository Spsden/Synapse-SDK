{
  "id": "google.keep",
  "name": "Google Keep",
  "version": "1.0.0",
  "description": "Create notes in Google Keep",
  "author": "Antigravity",
  "security": {
    "allowedDomains": [
      "keep.googleapis.com"
    ],
    "permissions": [
      "network"
    ]
  },
  "auth": {
    "provider": "google",
    "scopes": [
      "https://www.googleapis.com/auth/keep"
    ]
  },
  "triggers": [
    "create_note"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string"
      },
      "body": {
        "type": "string"
      }
    }
  }
}