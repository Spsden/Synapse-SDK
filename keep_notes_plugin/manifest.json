{
    "id": "com.google.keep.native",
    "name": "Google Keep (Native)",
    "version": "1.0.0",
    "description": "Create notes in Google Keep via native App",
    "author": "Antigravity",
    "security": {
        "allowedDomains": [],
        "permissions": [
            "system"
        ]
    },
    "triggers": [
        "create_note"
